# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=CineMaa
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# For Docker: postgresql://postgres:yourpassword@postgres:5432/movie_booking
# For Local:  postgresql://postgres:yourpassword@127.0.0.1:5432/movie_booking
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@127.0.0.1:5432/movie_booking?schema=public"

# ─── TMDB API ─────────────────────────────────────────────────────────────────
# Get your free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Redis ───────────────────────────────────────────────────────────────────
# For Docker: redis://redis:6379
# For Local:  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (use a long random string in production) ────────────────────
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ──────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Email — Gmail SMTP ──────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your real Gmail password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="CineMaa <your_gmail@gmail.com>"

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=10

# ─── Payment (Mock) ──────────────────────────────────────────────────────────
PAYMENT_GATEWAY_KEY=mock_payment_key
PAYMENT_GATEWAY_SECRET=mock_payment_secret

# ─── Seat Locking ────────────────────────────────────────────────────────────
SEAT_LOCK_TTL_SECONDS=300

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
